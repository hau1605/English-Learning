# Application
APP_ENV=development
LOG_LEVEL=INFO
APP_NAME=English Learning Crawler

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Backend Integration
BACKEND_API_URL=http://localhost:3001
BACKEND_API_KEY=your-backend-api-key-here

# Database (for direct access - optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=english_learning
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

# Crawler Settings
CRAWL_DELAY_MIN=1.0
CRAWL_DELAY_MAX=3.0
CRAWL_MAX_RETRIES=3
CRAWL_TIMEOUT=30
CRAWL_CONCURRENCY=5

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_HEADLESS=true

# Data Paths
DATA_DIR=/app/data
LOGS_DIR=/app/logs
CRAWL_OUTPUT_DIR=/app/data/crawl_output
