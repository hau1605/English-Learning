# APPLICATION
PORT=3636
NODE_ENV=development

# DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:port/english_learning

# REDIS
REDIS_HOST=localhost
REDIS_PORT=port
REDIS_PASSWORD=

# JWT AUTHENTICATION
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS & FRONTEND
FRONTEND_URL=http://localhost:port

# STORAGE (MinIO/S3)
S3_ENDPOINT=http://localhost:port
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=english-learning
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:port

# EMAIL / SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM_ADDRESS=noreply@englishlearning.com
EMAIL_FROM_NAME=English Learning Platform

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:port/api/v1/auth/google/callback

# RATE LIMITING
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# LOGGING
LOG_LEVEL=debug

# SECURITY SETTINGS
ENABLE_HTTPS=false
TRUST_PROXY=false
ENABLE_SWAGGER=true
SECURE_COOKIE=false

# Production settings (uncomment and configure):
# ENABLE_HTTPS=true
# TRUST_PROXY=true
# ENABLE_SWAGGER=false
# SECURE_COOKIE=true

# ============================================
# SSL CERTIFICATES (Production only)
# ============================================
# Path inside container where SSL certs are mounted
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
