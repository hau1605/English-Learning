# ============================================
# English Learning Platform - Backend Example Environment Variables
# ============================================
# IMPORTANT: Never commit actual .env files to git!
# Copy this file to .env.development or .env.production

# ============================================
# APPLICATION
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/english_learning

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Use strong secrets in production (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS & FRONTEND
# ============================================
# Development: http://localhost:3681
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:3681

# ============================================
# AI FEATURES (OpenAI)
# ============================================
OPENAI_API_KEY=your-openai-api-key

# ============================================
# STORAGE (MinIO/S3)
# ============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=english-learning
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# ============================================
# EMAIL / SMTP
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ============================================
# LOGGING
# ============================================
# Development: debug, verbose logging
# Production: info, warn, or error
LOG_LEVEL=debug

# ============================================
# SECURITY SETTINGS
# ============================================
# Development settings (relaxed):
ENABLE_HTTPS=false
TRUST_PROXY=false
ENABLE_SWAGGER=true
SECURE_COOKIE=false

# Production settings (uncomment and configure):
# ENABLE_HTTPS=true
# TRUST_PROXY=true
# ENABLE_SWAGGER=false
# SECURE_COOKIE=true

# ============================================
# SSL CERTIFICATES (Production only)
# ============================================
# Path inside container where SSL certs are mounted
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
