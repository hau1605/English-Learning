# ============================================
# English Learning Platform - Frontend Example Environment Variables
# ============================================
# IMPORTANT: Never commit actual .env files to git!
# Copy this file to .env.development or .env.production

# ============================================
# APPLICATION URLS
# ============================================
# Development:
NEXT_PUBLIC_APP_URL=http://localhost:3681
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Production:
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://your-domain.com

# ============================================
# FEATURE FLAGS
# ============================================
# Enable AI features (ChatGPT integration, etc.)
NEXT_PUBLIC_ENABLE_AI_FEATURES=false

# ============================================
# ENVIRONMENT
# ============================================
NEXT_PUBLIC_NODE_ENV=development
