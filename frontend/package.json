{
  "name": "english-learning-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev -p 3681",
    "dev:prod": "cross-env NODE_ENV=production next dev -p 3681",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build",
    "build:dev": "cross-env NEXT_TELEMETRY_DISABLED=1 NEXT_PUBLIC_NODE_ENV=development next build",
    "build:prod": "cross-env NEXT_TELEMETRY_DISABLED=1 NEXT_PUBLIC_NODE_ENV=production next build",
    "start": "next start",
    "start:dev": "next start -p 3681",
    "start:prod": "cross-env NODE_ENV=production next start -p 3681",
    "lint": "next lint",
    "test": "vitest",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "type-check": "tsc --noEmit",
    "docker:dev": "docker-compose -f ../docker-compose.dev.yml up --build frontend",
    "docker:prod": "docker-compose -f ../docker-compose.prod.yml up --build -d frontend"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.17.9",
    "@tanstack/react-table": "^8.11.6",
    "axios": "^1.6.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.309.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.6.1",
    "sonner": "^1.3.1",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.1.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.40.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.6"
  }
}
